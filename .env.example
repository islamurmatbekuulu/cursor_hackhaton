# === Google Maps Platform ===
GOOGLE_MAPS_API_KEY=            # frontend key (HTTP-referrer restricted)
GOOGLE_MAPS_BACKEND_KEY=        # Go backend key (IP restricted)
GOOGLE_MAPS_SIGNING_SECRET=     # Street View Static URL signing secret

# Public browser key for the web app (Next.js inlines NEXT_PUBLIC_* into the client bundle).
# MUST be an HTTP-referrer-restricted key with the Maps JavaScript API + Places API enabled.
# This is SEPARATE from the backend key(s) above. For local dev, put the real value in
# apps/web/.env.local (gitignored) — never commit the actual key.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# === Anthropic Claude (photo visual-pollution scoring) ===
# SERVER-SIDE secret. Read by the Go API at startup; required for POST
# /api/v1/score/photo (the app fails fast if scoring is enabled but this is unset).
# NEVER expose to the web/mobile client bundle, never log its value.
CLAUDE_API_KEY=                # sk-ant-...
CLAUDE_MODEL=                  # optional override; defaults to a current vision model
# CLAUDE_BASE_URL=             # optional; defaults to https://api.anthropic.com

# === Roboflow (legacy: Street View /detect only; NOT on the photo path) ===
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL=visual-pollution-pc2as/9

# === Hugging Face (model downloads only) ===
HF_TOKEN=

# === Internal service-to-service ===
INTERNAL_SIDECAR_TOKEN=         # openssl rand -hex 32
SIDECAR_URL=http://localhost:8000

# === App ===
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Web municipality console: use bundled demo submissions until Go /api/v1/submissions is live.
# Omit or set to "true" for demo mode (default). Set to "false" to fetch from the Go API via Next proxy.
NEXT_PUBLIC_USE_DEMO_DATA=true

# === Cursor CLI (headless pre-commit KVKK review) ===
CURSOR_API_KEY=
